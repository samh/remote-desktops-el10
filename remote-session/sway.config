# Minimal sway config for headless remote access via wayvnc.

exec_always --no-startup-id /usr/bin/wayvnc -C $HOME/.config/wayvnc/config

set $mod Mod4
set $term_launcher sh -lc 'if command -v ptyxis >/dev/null 2>&1; then exec ptyxis --standalone --new-window; fi; for t in gnome-terminal kgx xterm; do command -v "$t" >/dev/null 2>&1 && exec "$t"; done; exec swaynag -m "No terminal found. Install one or edit ~/.config/sway/config."'

# Preferred local bindings.
bindsym $mod+Return exec $term_launcher
bindsym $mod+Shift+e exec /usr/bin/swaymsg exit
bindsym $mod+Shift+r reload

# Alt (Mod1) bindings for VNC clients that pass Alt without grab mode.
bindsym Mod1+Return exec $term_launcher
bindsym Mod1+Shift+e exec /usr/bin/swaymsg exit
bindsym Mod1+Shift+r reload
bindsym Mod1+h focus left
bindsym Mod1+j focus down
bindsym Mod1+k focus up
bindsym Mod1+l focus right
bindsym Mod1+Shift+h move left
bindsym Mod1+Shift+j move down
bindsym Mod1+Shift+k move up
bindsym Mod1+Shift+l move right

# VNC-friendly fallbacks that avoid Super-key capture.
bindsym F1 focus left
bindsym F2 focus right
bindsym Shift+F1 move left
bindsym Shift+F2 move right
bindsym F3 splith
bindsym F4 splitv
bindsym F5 floating toggle
bindsym F6 fullscreen toggle
bindsym F8 kill
bindsym F9 exec $term_launcher
bindsym Ctrl+Alt+Return exec $term_launcher
bindsym F10 reload
bindsym Ctrl+Alt+Shift+r reload
bindsym Ctrl+Alt+Shift+e exec /usr/bin/swaymsg exit
bindsym Ctrl+Alt+1 exec /usr/bin/swaymsg output HEADLESS-1 resolution 1280x720
bindsym Ctrl+Alt+2 exec /usr/bin/swaymsg output HEADLESS-1 resolution 1600x900
bindsym Ctrl+Alt+3 exec /usr/bin/swaymsg output HEADLESS-1 resolution 1920x1080

exec_always --no-startup-id $term_launcher

focus_follows_mouse no
default_border pixel 2
